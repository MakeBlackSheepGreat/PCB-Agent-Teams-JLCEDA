# ── PCB-Agent-Teams — API keys ──
# Copy this file to `.env` and fill in your own keys.
# `.env` is gitignored and is never committed.
# Full reference + what each API does: see "External APIs" in README.md.
# NOTE: the uploaded demo sources parts for the JAPAN region (component-selecting-JP),
#       which is why the distributor keys below are needed.

# ── Required: DigiKey — primary buyable-gate (JP warehouse stock / price / lifecycle) ──
# Free OAuth app → https://developer.digikey.com/
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# ── Recommended: Mouser — second equal source (stock / price + datasheet links) ──
# https://www.mouser.com/api-hub/
MOUSER_SEARCH_API_KEY=
MOUSER_PART_API_KEY=

# ── Optional: element14 / Farnell — extra distributor source ──
# https://partner.element14.com/
ELEMENT14_API_KEY=

# ── Optional: Firecrawl — datasheet web-scrape fallback ──
# https://firecrawl.dev/
FIRECRAWL_API_KEY=

# ── No key needed: LCSC / JLCPCB are public (component search + library fetch) ──

# ── Optional: DigiKey locale (defaults to JP if unset) ──
# DIGIKEY_LOCALE_SITE=JP
# DIGIKEY_LOCALE_LANGUAGE=ja
# DIGIKEY_LOCALE_CURRENCY=JPY

# ── Optional: tool path overrides (only if not on a standard install path) ──
# KICAD_ROOT — optional: override the PROJECT workspace root (NOT the KiCad install path). Leave unset; scripts auto-detect kicad-cli on PATH.
# NGSPICE_PATH=/opt/homebrew/bin/ngspice
# LTSPICE_PATH=/Applications/LTspice.app/Contents/MacOS/LTspice
# Xyce — optional parallel SPICE backend; auto-detected on PATH, set only if installed elsewhere
# XYCE_PATH=/opt/homebrew/bin/Xyce
# SPICE_SIMULATOR=ngspice
